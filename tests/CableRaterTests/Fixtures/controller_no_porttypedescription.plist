<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!-- Raw-shape AppleTCControllerType10 node WITHOUT a PortTypeDescription key.
     This is the hardware-reality variant the real-port gate must still recognize:
     a known port-controller class with a resolvable PortNumber is a real USB-C port
     even when the controller does not publish PortTypeDescription == "USB-C". The
     registry name and ConnectionActive are the captured Port 3 shape; only the
     PortTypeDescription key is dropped to model a TC/HPM generation that labels the
     port differently. The gate trusts the named class plus the PortNumber here, and
     treats PortTypeDescription as confirming evidence reserved as a hard filter only
     for the broad IOPort catch-all.
-->
<array>
	<dict>
		<key>IOObjectClass</key>
		<string>AppleTCControllerType10</string>
		<key>IORegistryEntryName</key>
		<string>Port-USB-C</string>
		<key>IORegistryEntryLocation</key>
		<string>3</string>
		<key>PortNumber</key>
		<integer>3</integer>
		<key>PortType</key>
		<integer>2</integer>
		<key>ConnectionActive</key>
		<true/>
		<key>IOAccessoryDetect</key>
		<true/>
		<key>TransportsActive</key>
		<array>
			<string>CC</string>
		</array>
	</dict>
</array>
</plist>
