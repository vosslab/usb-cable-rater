# Bare bones: only artifacts that genuinely should never be committed.
# Bytecode (__pycache__, *.pyc), caches (.pytest_cache/, .mypy_cache/),
# virtual envs (.venv/, venv/, lib/, etc.) deliberately omitted -- user wants
# them visible so they can be deleted manually rather than silently growing.
# Type-checker caches (.pyright/, .pytype/) omitted -- not used.

# Distribution / build artifacts
build/
dist/
sdist/
*.egg
*.egg-info/

# mkdocs site output
site/
